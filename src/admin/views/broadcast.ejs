<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="mb-0"><i class="bi bi-megaphone"></i> Broadcast</h4>
</div>

<% if (sent !== null) { %>
  <div class="alert alert-success">✅ Broadcast sent! <strong><%= sent %></strong> delivered, <strong><%= failed %></strong> failed.</div>
<% } %>

<div class="row g-3">
  <div class="col-md-5">
    <div class="card">
      <div class="card-header">Send Message</div>
      <div class="card-body">
        <form method="POST" action="/admin/broadcast/send">
          <div class="mb-3">
            <label class="form-label">Message</label>
            <textarea name="message" class="form-control" rows="6" placeholder="Write your broadcast message here..." required></textarea>
            <div class="form-text">Supports Markdown formatting. Users will receive this as a Telegram message.</div>
          </div>
          <div class="mb-3">
            <label class="form-label">Filter by Status</label>
            <select name="filterStatus" class="form-select">
              <option value="">All Users</option>
              <option value="verified">Verified Only</option>
              <option value="pending">Pending Only</option>
              <option value="rejected">Rejected Only</option>
            </select>
          </div>
          <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-send"></i> Send Broadcast
          </button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-md-7">
    <div class="card">
      <div class="card-header">Broadcast History</div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Date</th>
              <th>Message</th>
              <th>Sent</th>
              <th>Failed</th>
            </tr>
          </thead>
          <tbody>
            <% broadcasts.forEach(b => { %>
              <tr>
                <td><small class="text-muted"><%= new Date(b.created_at).toLocaleString() %></small></td>
                <td><small><%= b.message_text.substring(0, 80) %><%= b.message_text.length > 80 ? '...' : '' %></small></td>
                <td><span class="badge bg-success"><%= b.sent_count %></span></td>
                <td><span class="badge bg-danger"><%= b.failed_count %></span></td>
              </tr>
            <% }) %>
            <% if (broadcasts.length === 0) { %>
              <tr><td colspan="4" class="text-center text-muted py-4">No broadcasts sent yet</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>