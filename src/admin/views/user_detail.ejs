<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <h5 class="mb-0 fw-semibold"><i class="bi bi-person me-2 text-primary"></i>User Profile</h5>
    <small class="text-muted"><%= user.first_name %> • ID #<%= user.id %></small>
  </div>
  <a href="/admin/users" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to Users</a>
</div>

<div class="row g-3">
  <!-- User Info Card -->
  <div class="col-lg-4">
    <div class="card">
      <div class="card-body text-center p-4">
        <div style="width:72px;height:72px;background:<%= user.status === 'verified' ? '#22c55e' : user.status === 'banned' ? '#ef4444' : user.status === 'rejected' ? '#f59e0b' : '#3b82f6' %>;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto .75rem;color:#fff;font-size:1.75rem;font-weight:700;"><%= (user.first_name || '?').charAt(0).toUpperCase() %></div>
        <h5 class="fw-semibold mb-1"><%= user.first_name %></h5>
        <% if (user.username) { %><p class="text-muted mb-2">@<%= user.username %></p><% } %>
        <span class="badge bg-<%= user.status === 'verified' ? 'success' : user.status === 'pending' ? 'warning text-dark' : user.status === 'rejected' ? 'danger' : 'dark' %> fs-6 px-3 py-1 mb-3 d-inline-block"><%= user.status.toUpperCase() %></span>

        <hr class="my-3">

        <div class="text-start">
          <div class="d-flex justify-content-between mb-2">
            <small class="text-muted">Telegram ID</small>
            <code><%= user.telegram_id %></code>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <small class="text-muted">Email</small>
            <small><%= user.email || '—' %></small>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <small class="text-muted">Phone</small>
            <small><%= user.phone || '—' %></small>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <small class="text-muted">Role</small>
            <span class="badge bg-<%= user.role === 'superadmin' ? 'danger' : user.role === 'admin' ? 'warning text-dark' : 'secondary' %>"><%= user.role %></span>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <small class="text-muted">Joined</small>
            <small><%= new Date(user.registered_at || Date.now()).toLocaleDateString() %></small>
          </div>
          <div class="d-flex justify-content-between mb-2">
            <small class="text-muted">Verified</small>
            <small><%= user.verified_at ? new Date(user.verified_at).toLocaleDateString() : '—' %></small>
          </div>
          <div class="d-flex justify-content-between">
            <small class="text-muted">Last Active</small>
            <small><%= new Date(user.last_active_at || Date.now()).toLocaleDateString() %></small>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Actions & Activity -->
  <div class="col-lg-8">
    <!-- Quick Actions -->
    <div class="card mb-3">
      <div class="card-header"><i class="bi bi-gear me-1"></i>Quick Actions</div>
      <div class="card-body">
        <div class="row g-2">
          <div class="col-6 col-md-3">
            <form method="POST" action="/admin/users/<%= user.telegram_id %>/action">
              <input type="hidden" name="action" value="verified">
              <input type="hidden" name="notes" value="Approved by admin via dashboard">
              <button type="submit" class="btn btn-success w-100" <%= user.status === 'verified' ? 'disabled' : '' %>>
                <i class="bi bi-check-lg"></i> Approve
              </button>
            </form>
          </div>
          <div class="col-6 col-md-3">
            <form method="POST" action="/admin/users/<%= user.telegram_id %>/action">
              <input type="hidden" name="action" value="pending">
              <input type="hidden" name="notes" value="Reset to pending by admin">
              <button type="submit" class="btn btn-warning w-100" <%= user.status === 'pending' ? 'disabled' : '' %>>
                <i class="bi bi-arrow-counterclockwise"></i> Reset
              </button>
            </form>
          </div>
          <div class="col-6 col-md-3">
            <form method="POST" action="/admin/users/<%= user.telegram_id %>/action">
              <input type="hidden" name="action" value="rejected">
              <input type="hidden" name="notes" value="Rejected by admin via dashboard">
              <button type="submit" class="btn btn-danger w-100" <%= user.status === 'rejected' ? 'disabled' : '' %>>
                <i class="bi bi-x-lg"></i> Reject
              </button>
            </form>
          </div>
          <div class="col-6 col-md-3">
            <form method="POST" action="/admin/users/<%= user.telegram_id %>/action">
              <input type="hidden" name="action" value="banned">
              <input type="hidden" name="notes" value="Banned by admin via dashboard">
              <button type="submit" class="btn btn-dark w-100" <%= user.status === 'banned' ? 'disabled' : '' %>>
                <i class="bi bi-slash-circle"></i> Ban
              </button>
            </form>
          </div>
        </div>

        <hr class="my-3">

        <form method="POST" action="/admin/users/<%= user.telegram_id %>/action" class="row g-2 align-items-end">
          <div class="col-md-5">
            <label class="form-label">Custom Action Note</label>
            <input type="text" name="notes" class="form-control form-control-sm" placeholder="e.g., User provided valid ID">
          </div>
          <div class="col-md-3">
            <label class="form-label">Action</label>
            <select name="action" class="form-select form-select-sm">
              <option value="verified">✅ Approve</option>
              <option value="rejected">❌ Reject</option>
              <option value="banned">🚫 Ban</option>
              <option value="pending">⏳ Reset to Pending</option>
            </select>
          </div>
          <div class="col-md-4">
            <button type="submit" class="btn btn-sm btn-primary w-100"><i class="bi bi-send me-1"></i>Apply Action</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Activity Log -->
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-clock-history me-1"></i>Activity History</span>
        <span class="badge bg-secondary"><%= logs.length %> entries</span>
      </div>
      <div class="card-body p-0">
        <% if (logs.length > 0) { %>
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Action</th>
                  <th>Performed By</th>
                  <th>Notes</th>
                  <th>Date & Time</th>
                </tr>
              </thead>
              <tbody>
                <% logs.forEach(log => { %>
                  <tr>
                    <td>
                      <% if (log.action === 'verified') { %>
                        <span class="badge bg-success">✅ Approved</span>
                      <% } else if (log.action === 'rejected') { %>
                        <span class="badge bg-danger">❌ Rejected</span>
                      <% } else if (log.action === 'requested') { %>
                        <span class="badge bg-info">📝 Registered</span>
                      <% } else if (log.action === 'banned') { %>
                        <span class="badge bg-dark">🚫 Banned</span>
                      <% } else { %>
                        <span class="badge bg-secondary"><%= log.action %></span>
                      <% } %>
                    </td>
                    <td><code><%= log.performed_by === user.telegram_id ? 'Self' : 'Admin #' + log.performed_by %></code></td>
                    <td><small><%= log.notes || '—' %></small></td>
                    <td><small class="text-muted"><%= new Date(log.created_at).toLocaleString() %></small></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <div class="text-center text-muted py-5">
            <i class="bi bi-activity d-block mb-2" style="font-size:2rem;"></i>
            No activity recorded for this user
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>