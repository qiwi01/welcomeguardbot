<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - WelcomeGuardBot Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * { font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif; }
    body {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
      padding: 1.5rem;
    }
    .login-wrapper { width: 100%; max-width: 420px; }
    .login-card {
      background: #fff; border-radius: 16px; padding: 2.5rem 2rem;
      box-shadow: 0 25px 50px rgba(0,0,0,.4);
    }
    .login-brand {
      text-align: center; margin-bottom: 2rem;
    }
    .login-brand .brand-icon {
      width: 56px; height: 56px; background: #3b82f6; border-radius: 14px;
      display: inline-flex; align-items: center; justify-content: center;
      color: #fff; font-size: 1.5rem; margin-bottom: .75rem;
    }
    .login-brand h4 { font-weight: 700; color: #0f172a; margin-bottom: .25rem; }
    .login-brand p { color: #64748b; font-size: .85rem; margin: 0; }
    .form-floating > .form-control { border-radius: 10px; height: 54px; padding: 1rem .85rem 0; }
    .form-floating > label { padding: 1rem .85rem; }
    .form-floating > .form-control:focus { border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59,130,246,.15); }
    .btn-login {
      background: #3b82f6; border: none; border-radius: 10px; padding: .75rem;
      font-weight: 600; font-size: .95rem; transition: all .2s;
    }
    .btn-login:hover { background: #2563eb; transform: translateY(-1px); box-shadow: 0 8px 20px rgba(59,130,246,.35); }
    .login-footer { text-align: center; margin-top: 1.5rem; color: #94a3b8; font-size: .8rem; }
    .login-footer a { color: #3b82f6; text-decoration: none; }
    .error-alert { border-radius: 10px; font-size: .85rem; border-left: 4px solid #ef4444; }
    .input-icon { position: relative; }
    .input-icon i { position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: #94a3b8; z-index: 5; }
    .input-icon .form-control { padding-left: 2.5rem; }
  </style>
</head>
<body>
  <div class="login-wrapper">
    <div class="login-card">
      <div class="login-brand">
        <div class="brand-icon"><i class="bi bi-shield-check"></i></div>
        <h4>WelcomeGuardBot</h4>
        <p>Admin Dashboard Login</p>
      </div>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger error-alert py-2 px-3 d-flex align-items-center gap-2">
          <i class="bi bi-exclamation-triangle-fill"></i>
          <span><%= error %></span>
        </div>
      <% } %>

      <form method="POST" action="/admin/login">
        <div class="mb-3">
          <label class="form-label fw-semibold" style="font-size:.85rem;">Telegram ID</label>
          <div class="input-icon">
            <i class="bi bi-telegram"></i>
            <input type="number" class="form-control" name="telegram_id" placeholder="Your numeric Telegram ID" required>
          </div>
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold" style="font-size:.85rem;">Admin Password</label>
          <div class="input-icon">
            <i class="bi bi-lock"></i>
            <input type="password" class="form-control" name="password" placeholder="Enter admin password" required>
          </div>
        </div>
        <button type="submit" class="btn btn-primary btn-login w-100">
          <i class="bi bi-box-arrow-in-right me-2"></i> Sign In
        </button>
      </form>

      <div class="login-footer">
        <p class="mb-0">Need your Telegram ID?</p>
        <a href="https://t.me/userinfobot" target="_blank">@userinfobot</a>
        <span class="mx-2">•</span>
        <a href="https://t.me/WelcomeGuardBot" target="_blank">@WelcomeGuardBot</a>
      </div>
    </div>
  </div>
</body>
</html>