<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - WelcomeGuardBot Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: linear-gradient(135deg, #1a1d23 0%, #2a2d35 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .login-card { background: #fff; border-radius: 16px; padding: 2.5rem; width: 100%; max-width: 420px; box-shadow: 0 10px 40px rgba(0,0,0,.3); }
    .login-card h3 { font-weight: 700; }
    .form-control { border-radius: 10px; padding: .75rem 1rem; }
    .btn-primary { border-radius: 10px; padding: .75rem; font-weight: 600; }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="text-center mb-4">
      <h3><i class="bi bi-shield-check"></i> WelcomeGuardBot</h3>
      <p class="text-muted">Admin Dashboard Login</p>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert alert-danger"><%= error %></div>
    <% } %>

    <form method="POST" action="/admin/login">
      <div class="mb-3">
        <label class="form-label">Telegram ID</label>
        <input type="number" class="form-control" name="telegram_id" placeholder="Your numeric Telegram ID" required>
      </div>
      <div class="mb-3">
        <label class="form-label">Admin Password</label>
        <input type="password" class="form-control" name="password" placeholder="Admin dashboard password" required>
      </div>
      <button type="submit" class="btn btn-primary w-100">Login</button>
    </form>

    <div class="mt-3 text-center small text-muted">
      <p>To get your Telegram ID, send <code>/start</code> to <a href="https://t.me/userinfobot" target="_blank">@userinfobot</a></p>
    </div>
  </div>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</body>
</html>