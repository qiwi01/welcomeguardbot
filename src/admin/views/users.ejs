<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="mb-0"><i class="bi bi-people"></i> Users</h4>
  <span class="text-muted"><%= total %> total</span>
</div>

<!-- Filters -->
<div class="card mb-3">
  <div class="card-body py-2">
    <form method="GET" class="row g-2 align-items-center">
      <div class="col-auto">
        <select name="status" class="form-select form-select-sm">
          <option value="">All Status</option>
          <option value="pending" <%= currentStatus === 'pending' ? 'selected' : '' %>>Pending</option>
          <option value="verified" <%= currentStatus === 'verified' ? 'selected' : '' %>>Verified</option>
          <option value="rejected" <%= currentStatus === 'rejected' ? 'selected' : '' %>>Rejected</option>
          <option value="banned" <%= currentStatus === 'banned' ? 'selected' : '' %>>Banned</option>
        </select>
      </div>
      <div class="col">
        <input type="text" name="search" class="form-control form-control-sm" placeholder="Search name, username, email, Telegram ID..." value="<%= currentSearch %>">
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-primary">Filter</button>
        <a href="/admin/users" class="btn btn-sm btn-outline-secondary">Reset</a>
      </div>
    </form>
  </div>
</div>

<!-- Users Table -->
<div class="card">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Telegram</th>
          <th>Email</th>
          <th>Status</th>
          <th>Role</th>
          <th>Joined</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
          <tr onclick="window.location='/admin/users/<%= u.telegram_id %>'" style="cursor:pointer;">
            <td><small class="text-muted">#<%= u.id %></small></td>
            <td><strong><%= u.first_name %></strong></td>
            <td><% if (u.username) { %>@<%= u.username %><% } else { %><small class="text-muted">—<% } %><br><small class="text-muted"><%= u.telegram_id %></small></td>
            <td><%= u.email || '—' %></td>
            <td>
              <% if (u.status === 'verified') { %>
                <span class="badge bg-success">Verified</span>
              <% } else if (u.status === 'pending') { %>
                <span class="badge bg-warning text-dark">Pending</span>
              <% } else if (u.status === 'rejected') { %>
                <span class="badge bg-danger">Rejected</span>
              <% } else { %>
                <span class="badge bg-dark">Banned</span>
              <% } %>
            </td>
            <td><%= u.role %></td>
            <td><small class="text-muted"><%= new Date(u.created_at).toLocaleDateString() %></small></td>
          </tr>
        <% }) %>
        <% if (users.length === 0) { %>
          <tr><td colspan="7" class="text-center text-muted py-4">No users found</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
<nav class="mt-3">
  <ul class="pagination pagination-sm justify-content-center">
    <% for (let p = 1; p <= totalPages; p++) { %>
      <li class="page-item <%= p === page ? 'active' : '' %>">
        <a class="page-link" href="/admin/users?page=<%= p %><%= currentStatus ? '&status=' + currentStatus : '' %><%= currentSearch ? '&search=' + currentSearch : '' %>"><%= p %></a>
      </li>
    <% } %>
  </ul>
</nav>
<% } %>