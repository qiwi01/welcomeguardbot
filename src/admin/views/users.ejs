<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <h5 class="mb-0 fw-semibold"><i class="bi bi-people me-2 text-primary"></i>User Management</h5>
    <small class="text-muted"><%= total %> total users</small>
  </div>
  <div class="d-flex gap-2">
    <button class="btn btn-sm btn-outline-success" onclick="exportCSV()"><i class="bi bi-download me-1"></i>Export CSV</button>
  </div>
</div>

<!-- Filters -->
<div class="card mb-3">
  <div class="card-body py-3">
    <form method="GET" class="row g-2 align-items-end">
      <div class="col-md-3">
        <label class="form-label">Status Filter</label>
        <select name="status" class="form-select form-select-sm">
          <option value="">All Statuses</option>
          <option value="pending" <%= currentStatus === 'pending' ? 'selected' : '' %>>Pending</option>
          <option value="verified" <%= currentStatus === 'verified' ? 'selected' : '' %>>Verified</option>
          <option value="rejected" <%= currentStatus === 'rejected' ? 'selected' : '' %>>Rejected</option>
          <option value="banned" <%= currentStatus === 'banned' ? 'selected' : '' %>>Banned</option>
        </select>
      </div>
      <div class="col-md-5">
        <label class="form-label">Search</label>
        <input type="text" name="search" class="form-control form-control-sm" placeholder="Name, username, Telegram ID..." value="<%= currentSearch %>">
      </div>
      <div class="col-md-4">
        <button type="submit" class="btn btn-sm btn-primary me-1"><i class="bi bi-search me-1"></i>Search</button>
        <a href="/admin/users" class="btn btn-sm btn-outline-secondary"><i class="bi bi-x-circle me-1"></i>Clear</a>
      </div>
    </form>
  </div>
</div>

<!-- Users Table -->
<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th style="width:40px;">#</th>
            <th>User</th>
            <th>Telegram ID</th>
            <th>Contact</th>
            <th>Status</th>
            <th>Role</th>
            <th>Joined</th>
            <th class="text-end" style="width:50px;"></th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(u => { %>
            <tr onclick="window.location='/admin/users/<%= u.telegram_id %>'">
              <td><small class="text-muted"><%= u.id %></small></td>
              <td>
                <div class="d-flex align-items-center gap-2">
                  <div style="width:32px;height:32px;background:<%= u.status === 'verified' ? '#dcfce7' : u.status === 'banned' ? '#fee2e2' : '#fef9c3' %>;color:<%= u.status === 'verified' ? '#166534' : u.status === 'banned' ? '#991b1b' : '#854d0e' %>;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:.8rem;flex-shrink:0;"><%= (u.first_name || '?').charAt(0).toUpperCase() %></div>
                  <div>
                    <div class="fw-semibold" style="font-size:.85rem;"><%= u.first_name %></div>
                    <% if (u.username) { %><small class="text-muted">@<%= u.username %></small><% } %>
                  </div>
                </div>
              </td>
              <td><code style="font-size:.75rem;"><%= u.telegram_id %></code></td>
              <td>
                <% if (u.email) { %><small><i class="bi bi-envelope me-1"></i><%= u.email %></small><br><% } %>
                <% if (u.phone) { %><small><i class="bi bi-telephone me-1"></i><%= u.phone %></small><% } %>
                <% if (!u.email && !u.phone) { %><small class="text-muted">—</small><% } %>
              </td>
              <td>
                <% if (u.status === 'verified') { %>
                  <span class="badge bg-success">Verified</span>
                <% } else if (u.status === 'pending') { %>
                  <span class="badge bg-warning text-dark">Pending</span>
                <% } else if (u.status === 'rejected') { %>
                  <span class="badge bg-danger">Rejected</span>
                <% } else { %>
                  <span class="badge bg-dark">Banned</span>
                <% } %>
              </td>
              <td><small><%= u.role %></small></td>
              <td><small class="text-muted"><%= new Date(u.registered_at || Date.now()).toLocaleDateString() %></small></td>
              <td class="text-end"><i class="bi bi-chevron-right text-muted"></i></td>
            </tr>
          <% }) %>
          <% if (users.length === 0) { %>
            <tr><td colspan="8" class="text-center text-muted py-5"><i class="bi bi-inbox d-block mb-2" style="font-size:2rem;"></i>No users found matching your criteria</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Pagination -->
<% if (totalPages > 1) { %>
<nav class="mt-3 d-flex justify-content-between align-items-center">
  <small class="text-muted">Page <%= page %> of <%= totalPages %> (<%= total %> total)</small>
  <ul class="pagination pagination-sm mb-0">
    <% if (page > 1) { %>
      <li class="page-item"><a class="page-link" href="/admin/users?page=<%= page - 1 %><%= currentStatus ? '&status=' + currentStatus : '' %><%= currentSearch ? '&search=' + currentSearch : '' %>">Prev</a></li>
    <% } %>
    <% for (let p = Math.max(1, page - 2); p <= Math.min(totalPages, page + 2); p++) { %>
      <li class="page-item <%= p === page ? 'active' : '' %>">
        <a class="page-link" href="/admin/users?page=<%= p %><%= currentStatus ? '&status=' + currentStatus : '' %><%= currentSearch ? '&search=' + currentSearch : '' %>"><%= p %></a>
      </li>
    <% } %>
    <% if (page < totalPages) { %>
      <li class="page-item"><a class="page-link" href="/admin/users?page=<%= page + 1 %><%= currentStatus ? '&status=' + currentStatus : '' %><%= currentSearch ? '&search=' + currentSearch : '' %>">Next</a></li>
    <% } %>
  </ul>
</nav>
<% } %>

<script>
function exportCSV() {
  // Collect visible table data into CSV
  const rows = [];
  document.querySelectorAll('.table tbody tr').forEach(tr => {
    // Skip 'no results' row
    if (tr.querySelector('td[colspan]')) return;
    const cells = tr.querySelectorAll('td');
    if (cells.length < 7) return;
    const name = cells[1].innerText.trim();
    const username = cells[1].querySelector('small')?.innerText?.replace('@','').trim() || '';
    const telegramId = cells[2].innerText.trim();
    const status = cells[4].innerText.trim();
    const email = cells[3].querySelector('.bi-envelope')?.parentElement?.innerText?.trim() || '';
    rows.push({ name, username, telegramId, status, email });
  });
  if (rows.length === 0) return;
  let csv = 'Name,Username,Telegram ID,Email,Status\n';
  rows.forEach(r => { csv += `"${r.name}","${r.username}","${r.telegramId}","${r.email}","${r.status}"\n`; });
  const blob = new Blob([csv], { type: 'text/csv' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a'); a.href = url; a.download = 'users-export.csv'; a.click();
  URL.revokeObjectURL(url);
}
</script>