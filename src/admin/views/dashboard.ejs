<div class="row g-3 mb-4">
  <div class="col-md-3 col-6">
    <div class="card stat-card bg-primary text-white p-3">
      <div class="stat-icon"><i class="bi bi-people"></i></div>
      <p class="stat-label">Total Users</p>
      <p class="stat-value"><%= stats.total %></p>
      <small style="opacity:.7"><i class="bi bi-arrow-up"></i> All time</small>
    </div>
  </div>
  <div class="col-md-3 col-6">
    <div class="card stat-card bg-success text-white p-3">
      <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
      <p class="stat-label">Verified</p>
      <p class="stat-value"><%= stats.verified %></p>
      <small style="opacity:.7"><%= stats.total > 0 ? Math.round(stats.verified/stats.total*100) : 0 %>% of all users</small>
    </div>
  </div>
  <div class="col-md-3 col-6">
    <div class="card stat-card bg-warning text-dark p-3">
      <div class="stat-icon"><i class="bi bi-hourglass-split"></i></div>
      <p class="stat-label">Pending</p>
      <p class="stat-value"><%= stats.pending %></p>
      <small style="opacity:.7">Awaiting verification</small>
    </div>
  </div>
  <div class="col-md-3 col-6">
    <div class="card stat-card bg-info text-white p-3">
      <div class="stat-icon"><i class="bi bi-graph-up"></i></div>
      <p class="stat-label">Joined Today</p>
      <p class="stat-value"><%= stats.joined_today %></p>
      <small style="opacity:.7">Last 24 hours</small>
    </div>
  </div>
</div>

<div class="row g-3">
  <!-- Recent Users -->
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-people text-primary me-1"></i> Recent Users</span>
        <a href="/admin/users" class="btn btn-sm btn-outline-primary">View All <i class="bi bi-arrow-right ms-1"></i></a>
      </div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Name</th>
              <th>Status</th>
              <th>Joined</th>
              <th class="text-end">Action</th>
            </tr>
          </thead>
          <tbody>
            <% recentUsers.forEach(u => { %>
              <tr onclick="window.location='/admin/users/<%= u.telegram_id %>'">
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <div class="user-avatar" style="width:30px;height:30px;font-size:.7rem;background:#e2e8f0;color:#475569;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:600;"><%= (u.first_name || '?').charAt(0).toUpperCase() %></div>
                    <div>
                      <div class="fw-semibold" style="font-size:.85rem;"><%= u.first_name %></div>
                      <% if (u.username) { %><small class="text-muted">@<%= u.username %></small><% } %>
                    </div>
                  </div>
                </td>
                <td>
                  <% if (u.status === 'verified') { %>
                    <span class="badge bg-success-subtle text-success border border-success-subtle">Verified</span>
                  <% } else if (u.status === 'pending') { %>
                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle">Pending</span>
                  <% } else if (u.status === 'rejected') { %>
                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Rejected</span>
                  <% } else if (u.status === 'banned') { %>
                    <span class="badge bg-dark-subtle text-dark border border-dark-subtle">Banned</span>
                  <% } %>
                </td>
                <td><small class="text-muted"><%= new Date(u.registered_at || Date.now()).toLocaleDateString() %></small></td>
                <td class="text-end"><small class="text-primary"><i class="bi bi-chevron-right"></i></small></td>
              </tr>
            <% }) %>
            <% if (recentUsers.length === 0) { %>
              <tr><td colspan="4" class="text-center text-muted py-4"><i class="bi bi-inbox d-block mb-2" style="font-size:1.5rem;"></i>No users registered yet</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Recent Activity Timeline -->
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-activity text-success me-1"></i> Recent Activity</span>
        <a href="/admin/logs" class="btn btn-sm btn-outline-secondary">View All <i class="bi bi-arrow-right ms-1"></i></a>
      </div>
      <div class="card-body">
        <% if (recentLogs.length > 0) { %>
          <ul class="timeline">
            <% recentLogs.slice(0, 6).forEach(log => { %>
              <li class="timeline-item">
                <div class="timeline-dot <%= log.action === 'verified' ? 'success' : log.action === 'rejected' ? 'danger' : log.action === 'banned' ? 'dark' : 'info' %>"></div>
                <div class="d-flex justify-content-between">
                  <div>
                    <strong><%= log.first_name %></strong>
                    <% if (log.action === 'verified') { %>
                      <span class="badge bg-success-subtle text-success ms-1">Approved</span>
                    <% } else if (log.action === 'rejected') { %>
                      <span class="badge bg-danger-subtle text-danger ms-1">Rejected</span>
                    <% } else if (log.action === 'requested') { %>
                      <span class="badge bg-info-subtle text-info ms-1">Registered</span>
                    <% } else if (log.action === 'banned') { %>
                      <span class="badge bg-dark-subtle text-dark ms-1">Banned</span>
                    <% } else { %>
                      <span class="badge bg-secondary-subtle text-secondary ms-1"><%= log.action %></span>
                    <% } %>
                  </div>
                  <small class="text-muted"><%= new Date(log.created_at).toLocaleDateString() %></small>
                </div>
                <% if (log.notes) { %><small class="text-muted d-block mt-1"><%= log.notes %></small><% } %>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <div class="text-center text-muted py-4">
            <i class="bi bi-clock-history d-block mb-2" style="font-size:1.5rem;"></i>
            No recent activity
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Recent Broadcasts -->
<% if (recentBroadcasts && recentBroadcasts.length > 0) { %>
<div class="row mt-3">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-megaphone text-warning me-1"></i> Recent Broadcasts</span>
        <a href="/admin/broadcast" class="btn btn-sm btn-outline-warning">View All <i class="bi bi-arrow-right ms-1"></i></a>
      </div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr><th>Message</th><th class="text-center">Sent</th><th class="text-center">Failed</th><th>Date</th></tr>
          </thead>
          <tbody>
            <% recentBroadcasts.forEach(b => { %>
              <tr>
                <td><small><%= b.message_text.substring(0, 60) %><%= b.message_text.length > 60 ? '...' : '' %></small></td>
                <td class="text-center"><span class="badge bg-success"><%= b.sent_count %></span></td>
                <td class="text-center"><span class="badge bg-danger"><%= b.failed_count %></span></td>
                <td><small class="text-muted"><%= new Date(b.created_at).toLocaleDateString() %></small></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<% } %>