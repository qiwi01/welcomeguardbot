<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0"><i class="bi bi-speedometer2"></i> Dashboard</h4>
  <span class="text-muted">Welcome, <%= username %></span>
</div>

<!-- Stats Cards -->
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card stat-card bg-primary text-white p-3">
      <div class="d-flex justify-content-between">
        <div>
          <h6 class="mb-0 opacity-75">Total Users</h6>
          <h2 class="mb-0"><%= stats.total %></h2>
        </div>
        <div class="stat-icon"><i class="bi bi-people"></i></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card bg-success text-white p-3">
      <div class="d-flex justify-content-between">
        <div>
          <h6 class="mb-0 opacity-75">Verified</h6>
          <h2 class="mb-0"><%= stats.verified %></h2>
        </div>
        <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card bg-warning text-dark p-3">
      <div class="d-flex justify-content-between">
        <div>
          <h6 class="mb-0 opacity-75">Pending</h6>
          <h2 class="mb-0"><%= stats.pending %></h2>
        </div>
        <div class="stat-icon"><i class="bi bi-hourglass-split"></i></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card stat-card bg-info text-white p-3">
      <div class="d-flex justify-content-between">
        <div>
          <h6 class="mb-0 opacity-75">Joined Today</h6>
          <h2 class="mb-0"><%= stats.joined_today %></h2>
        </div>
        <div class="stat-icon"><i class="bi bi-graph-up"></i></div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3">
  <!-- Recent Users -->
  <div class="col-md-6">
    <div class="card">
      <div class="card-header d-flex justify-content-between">
        <span><i class="bi bi-people"></i> Recent Users</span>
        <a href="/admin/users" class="btn btn-sm btn-outline-secondary">View All</a>
      </div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Name</th>
              <th>Status</th>
              <th>Joined</th>
            </tr>
          </thead>
          <tbody>
            <% recentUsers.forEach(u => { %>
              <tr onclick="window.location='/admin/users/<%= u.telegram_id %>'">
                <td><%= u.first_name %><% if (u.username) { %> <small class="text-muted">@<%= u.username %></small><% } %></td>
                <td>
                  <% if (u.status === 'verified') { %>
                    <span class="badge bg-success badge-status">Verified</span>
                  <% } else if (u.status === 'pending') { %>
                    <span class="badge bg-warning text-dark badge-status">Pending</span>
                  <% } else if (u.status === 'rejected') { %>
                    <span class="badge bg-danger badge-status">Rejected</span>
                  <% } else if (u.status === 'banned') { %>
                    <span class="badge bg-dark badge-status">Banned</span>
                  <% } %>
                </td>
                <td><small class="text-muted"><%= new Date(u.created_at).toLocaleDateString() %></small></td>
              </tr>
            <% }) %>
            <% if (recentUsers.length === 0) { %>
              <tr><td colspan="3" class="text-center text-muted py-3">No users yet</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Recent Logs -->
  <div class="col-md-6">
    <div class="card">
      <div class="card-header d-flex justify-content-between">
        <span><i class="bi bi-clock-history"></i> Recent Activity</span>
        <a href="/admin/logs" class="btn btn-sm btn-outline-secondary">View All</a>
      </div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>User</th>
              <th>Action</th>
              <th>Time</th>
            </tr>
          </thead>
          <tbody>
            <% recentLogs.forEach(log => { %>
              <tr>
                <td><%= log.first_name %><% if (log.username) { %> <small>@<%= log.username %></small><% } %></td>
                <td>
                  <% if (log.action === 'verified') { %>
                    <span class="badge bg-success">Approved</span>
                  <% } else if (log.action === 'rejected') { %>
                    <span class="badge bg-danger">Rejected</span>
                  <% } else if (log.action === 'requested') { %>
                    <span class="badge bg-info">Registered</span>
                  <% } else { %>
                    <span class="badge bg-secondary"><%= log.action %></span>
                  <% } %>
                </td>
                <td><small class="text-muted"><%= new Date(log.created_at).toLocaleString() %></small></td>
              </tr>
            <% }) %>
            <% if (recentLogs.length === 0) { %>
              <tr><td colspan="3" class="text-center text-muted py-3">No activity yet</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>